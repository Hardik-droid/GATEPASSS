{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server:dev": "tsx server/index.ts",
    "dev:full": "concurrently -k \"npm:server:dev\" \"npm:dev\"",
    "build": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-server/index.js",
    "build:full": "npm run build",
    "start": "node dist-server/index.js",
    "preview": "vite preview --host 0.0.0.0",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:api": "tsx --test server/app.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@react-oauth/google": "^0.13.5",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "pino-http": "^11.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "supertest": "^7.2.2",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
